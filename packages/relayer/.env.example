# Server Configuration
PORT=3001

# Network Configuration
RPC_URL=https://public-node.testnet.rsk.co
CHAIN_ID=31

# Contract Addresses (update after deployment)
FORWARDER_ADDRESS=deployed_oz_forwarder_address
EXAMPLE_TARGET_ADDRESS=deployed_example_target_address

# Allowed Target Contracts (comma-separated list)
# If ALLOWED_TARGETS is set, only these contracts can be called via the relayer
# If not set, falls back to EXAMPLE_TARGET_ADDRESS for backward compatibility
# Example: ALLOWED_TARGETS=0x123...,0x456...,0x789...
ALLOWED_TARGETS=

# Relayer Wallet (needs RBTC for gas fees)
RELAYER_PRIVATE_KEY=your_relayer_private_key_here

# Rate Limiting (optional - defaults shown)
RATE_LIMIT_PER_IP_PER_MIN=20
RATE_LIMIT_PER_IP_PER_HOUR=100
RATE_LIMIT_PER_ADDRESS_PER_MIN=10
RATE_LIMIT_PER_ADDRESS_PER_HOUR=50
RATE_LIMIT_GLOBAL_CONCURRENT=100

# Budget Limits (optional - defaults shown)
DAILY_BUDGET_RBTC=0.1

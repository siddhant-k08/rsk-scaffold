# Template for Hardhat environment variables.

# To use this template, copy this file, rename it .env, and fill in the values.

# If not set, we provide default values (check `hardhat.config.ts`) so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# To access the values stored in this .env file you can use: process.env.VARIABLENAME

# REQUIRED: Private key for the deployer account (without 0x prefix)
# For local development, you can use a test private key
# For production, NEVER commit your real private key to version control
# Generate a new account with: yarn generate
DEPLOYER_PRIVATE_KEY=

# REQUIRED: Rootstock RPC URL
# For Rootstock Testnet: https://rpc.testnet.rootstock.io/YOUR_API_KEY_HERE
# For Rootstock Mainnet: https://rpc.mainnet.rootstock.io/YOUR_API_KEY_HERE
# Get your API key from: https://rpc.rootstock.io/
# Or use public endpoint (rate limited): https://public-node.testnet.rsk.co
ROOTSTOCK_RPC_URL=

# OPTIONAL: Forking configuration for local development
FORKING_URL=
MAINNET_FORKING_ENABLED=false
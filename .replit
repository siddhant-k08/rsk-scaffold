modules = ["nodejs-18"]

run = [
    "bash",
    "-c",
    """

# Function to handle .env configuration for a specific package
configure_env() {
    local package_name=$1
    local package_dir=$2
    local env_file=$3
    local example_file=$4
    shift 4
    local keys=("$@")
    
    echo "=== Configuring $package_name environment variables ==="
    echo "Package directory: $package_dir"
    echo "Environment file: $env_file"
    echo
    
    # Create package directory if it doesn't exist
    mkdir -p "$package_dir"
    
    # Check if .env file exists, if not, copy from example
    if [ ! -f "$env_file" ]; then
        if [ -f "$example_file" ]; then
            echo "Creating $env_file from $example_file template..."
            cp "$example_file" "$env_file"
        else
            echo "Creating $env_file with necessary keys."
            for key in "${keys[@]}"; do
                echo "$key=" >> "$env_file"
            done
        fi
    else
        # Ensure all required keys exist in the file
        for key in "${keys[@]}"; do
            if ! grep -q "^$key=" "$env_file"; then
                echo "Adding missing key: $key"
                echo "$key=" >> "$env_file"
            fi
        done
    fi

    # Read existing keys from .env file
    existing_keys=($(grep -E "^[A-Z_]+=" "$env_file" | cut -d '=' -f 1))

    # Display the keys to the user
    echo "Found the following required keys in $env_file:"
    for key in "${keys[@]}"; do
        echo "- $key"
    done

    # Prompt the user for values for each required key that doesn't have a value
    echo
    echo "Please enter values for required environment variables:"
    echo "(Press Enter to skip optional variables or if already set)"
    echo
    
    local missing_required=false
    for key in "${keys[@]}"; do
        # Check if the key has a value in the .env file
        current_value=$(grep "^$key=" "$env_file" | cut -d '=' -f 2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        
        # If the current value is empty, prompt the user for input
        if [ -z "$current_value" ]; then
            echo "⚠️  $key is not set"
            read -p "Enter value for $key (required): " input
            if [ -n "$input" ]; then
                # Update the .env file with the new value
                sed -i "s|^$key=.*|$key=$input|" "$env_file"
                echo "✓ Updated $key in $env_file."
            else
                echo "⚠️  WARNING: $key is still empty - deployment may fail!"
                missing_required=true
            fi
            echo
        else
            echo "✓ $key already configured"
        fi 
    done
    
    if [ "$missing_required" = true ]; then
        echo "⚠️  WARNING: Some required variables are not set!"
        echo "You can set them later by editing $env_file"
        echo
    fi
}

echo "RSK Scaffold Replit Setup"
echo "============================"
echo

# Configure Hardhat environment variables
hardhat_keys=("DEPLOYER_PRIVATE_KEY" "ROOTSTOCK_RPC_URL")
configure_env "Hardhat" "packages/hardhat" "packages/hardhat/.env" "packages/hardhat/.env.example" "${hardhat_keys[@]}"

# Configure NextJS environment variables  
nextjs_keys=("NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID" "NEXT_PUBLIC_ROOTSTOCK_RPC_URL")
configure_env "NextJS" "packages/nextjs" "packages/nextjs/.env.local" "packages/nextjs/.env.example" "${nextjs_keys[@]}"

echo "Environment configuration completed!"
echo

# Validate critical environment variables before proceeding
echo "=== Validating Environment Variables ==="
echo

validate_env_var() {
    local file=$1
    local var=$2
    local value=$(grep "^$var=" "$file" 2>/dev/null | cut -d '=' -f 2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    
    if [ -z "$value" ]; then
        echo "❌ $var is not set in $file"
        return 1
    else
        echo "✓ $var is configured"
        return 0
    fi
}

# Check Hardhat variables
hardhat_valid=true
if ! validate_env_var "packages/hardhat/.env" "DEPLOYER_PRIVATE_KEY"; then
    hardhat_valid=false
fi
if ! validate_env_var "packages/hardhat/.env" "ROOTSTOCK_RPC_URL"; then
    hardhat_valid=false
fi

# Check NextJS variables
nextjs_valid=true
if ! validate_env_var "packages/nextjs/.env.local" "NEXT_PUBLIC_ROOTSTOCK_RPC_URL"; then
    nextjs_valid=false
fi

echo

if [ "$hardhat_valid" = false ]; then
    echo "⚠️  WARNING: Hardhat environment variables are incomplete!"
    echo "Deployment may fail. Please edit packages/hardhat/.env manually."
    echo "See docs/ENVIRONMENT_VARIABLES.md for detailed instructions."
    echo
    read -p "Continue anyway? (y/N): " continue_deploy
    if [[ ! "$continue_deploy" =~ ^[Yy]$ ]]; then
        echo "Setup cancelled. Please configure environment variables and restart."
        exit 1
    fi
fi

if [ "$nextjs_valid" = false ]; then
    echo "⚠️  WARNING: NextJS environment variables are incomplete!"
    echo "Frontend may not work correctly. Please edit packages/nextjs/.env.local manually."
    echo
fi

echo "=== Proceeding with Installation ==="
echo

# Install root dependencies
echo "Installing root dependencies..."
yarn

# Fix hardhat-deploy jsonfile dependency issue in Replit
echo "Fixing hardhat-deploy jsonfile dependency for Replit..."
cd packages/hardhat
echo "Installing jsonfile to resolve fs-extra dependency..."
yarn add jsonfile
cd ../..
echo "jsonfile installed"

# Deploy contracts
echo "Deploying contracts..."
yarn deploy
echo

# echo "contract deployed successfully!"

# echo "Running NextJS app..."
yarn start
echo

echo "Setup completed successfully!"
# """,
]

[nix]
channel = "stable-24_05"

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80